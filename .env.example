# .env.example
# Copy to .env and fill in real values. NEVER commit .env.

# --- AI Gateway ---
AI_GATEWAY_API_KEY=sk-or-v1-your-openrouter-key
AI_GATEWAY_BASE_URL=https://openrouter.ai/api/v1

# --- OpenClaw Gateway ---
MOLTBOT_GATEWAY_TOKEN=your-moltbot-gateway-token
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token

# --- Mentra ---
MENTRA_API_KEY=your-mentra-api-key

# --- Channels (optional) ---
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
