# terraform/terraform.tfvars.example
# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it contains secrets.

# GCP
gcp_project_id   = "my-gcp-project-id"
gcp_region       = "us-east1"
gcp_zone         = "us-east1-b"
gcp_machine_type = "e2-medium"

# Networking
domain           = "aebots.org"
ssh_allowed_ips  = ["203.0.113.0/32"]  # Your IP

# Monitoring (optional)
monitoring_email = "alerts@example.com"

# Secrets (optional — set to true to use GCP Secret Manager instead of .env)
use_secret_manager = false
